# ============================================================
# Files and folders that git should IGNORE
# ============================================================
# These are generated files — they can be recreated by running
# the code, so we don't need to store them in version control.
# ============================================================

# --- Python ---
# When Python runs your code, it creates compiled bytecode files
# in __pycache__ folders. These are machine-specific and not useful
# to share.
__pycache__/
*.pyc

# --- Virtual environment ---
# A virtual environment is an isolated Python installation for this
# project. It can contain hundreds of MBs of library files.
# Each developer creates their own, so we don't commit it.
venv/
.venv/

# --- Model outputs ---
# Trained model files can be large (MBs). They are generated by
# running train.py, so anyone can recreate them.
outputs/model.pth

# --- OS files ---
# macOS creates .DS_Store files in every folder you open in Finder.
# They store folder view preferences and are not useful for the project.
.DS_Store
